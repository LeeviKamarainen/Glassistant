# Copy to .env and adjust. Loaded by the backend via pydantic-settings.

# Path to the SQLite database file (relative to the backend cwd, or absolute).
GLASSISTANT_DB_PATH=./glassistant.db

# Default weather widget location (Helsinki). Each weather widget may override
# via its config_json {"lat": ..., "lon": ...}.
GLASSISTANT_DEFAULT_WEATHER_LAT=60.1699
GLASSISTANT_DEFAULT_WEATHER_LON=24.9384

# Comma-separated list. Vite dev server is on 5173 by default.
GLASSISTANT_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# HSL Digitransit routing API key. Register at https://portal.digitransit.fi
# Leave empty to disable the transit proxy endpoint.
GLASSISTANT_DIGITRANSIT_API_KEY=your-api-key-here

# Home coordinates for the Transit widget. These are exposed to the frontend via
# GET /api/system so they can be used as the "Home" route origin without being
# hardcoded anywhere in the codebase or committed to git.
GLASSISTANT_HOME_LAT=60.0000
GLASSISTANT_HOME_LON=24.0000

# Spotify OAuth 2.0 credentials.
# 1. Go to https://developer.spotify.com/dashboard and create an app.
# 2. In the app settings, add http://127.0.0.1:8000/api/spotify/callback as a Redirect URI.
# 3. Paste the Client ID and Client Secret below.
# Leave both empty to disable the Spotify widget.
GLASSISTANT_SPOTIFY_CLIENT_ID=your-spotify-client-id
GLASSISTANT_SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
GLASSISTANT_SPOTIFY_REDIRECT_URI=http://127.0.0.1:8000/api/spotify/callback

# Ollama AI agent. Point at a running Ollama instance.
# Tool-capable models: llama3.1, llama3.2, qwen2.5, qwen2.5-coder, mistral-nemo
GLASSISTANT_OLLAMA_BASE_URL=http://localhost:11434
GLASSISTANT_OLLAMA_MODEL=llama3.2

# Google Calendar OAuth 2.0 credentials.
# 1. Go to https://console.cloud.google.com and create a project.
# 2. Enable the Google Calendar API.
# 3. Create an OAuth 2.0 web application credential.
# 4. Add http://localhost:8000/api/calendar/callback as an authorized redirect URI.
# 5. Paste the client ID and secret below.
# Leave both empty to disable the calendar integration.
GLASSISTANT_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GLASSISTANT_GOOGLE_CLIENT_SECRET=your-client-secret
GLASSISTANT_GOOGLE_REDIRECT_URI=http://localhost:8000/api/calendar/callback
